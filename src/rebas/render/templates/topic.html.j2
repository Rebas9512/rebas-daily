{% extends "base.html.j2" %}
{% block title %}{{ topic.title }} · rebas_daily{% endblock %}
{% block nav %}<a href="issue-{{ issue_date }}.html">← {{ issue_date }} 当期</a>{% endblock %}
{% block content %}
<article class="topic">
  <p class="topic-meta">{{ issue_date }} · {{ board_name }}
    {% if topic.slot == 'headline' %}· 头条{% elif topic.decision == 'brief' %}· 速览{% endif %}</p>
  <h1>{{ topic.title }}</h1>
  {% if image %}<figure class="topic-figure"><img src="{{ image }}" alt=""
      onerror="this.closest('figure').remove()"></figure>{% endif %}

  <div class="prose">{{ body_html | safe }}</div>

  <aside class="sources">
    <h2>供稿材料</h2>
    <ol>
      {% for s in sources %}
      <li><a href="{{ s.url }}" target="_blank" rel="noopener">{{ s.title }}</a>
        <span class="brief-source">{{ s.source }}</span></li>
      {% endfor %}
    </ol>
  </aside>
</article>
{% endblock %}
