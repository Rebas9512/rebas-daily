---
import Layout from "../layouts/Layout.astro";
import IssueHome from "../components/IssueHome.astro";
import { site, latestIssue } from "../lib/data";

const issue = latestIssue;
if (!issue) {
  throw new Error("没有期次数据：先跑 rebas render 导出 web/data/");
}
const issueLabel = `NO.${String(issue.no).padStart(3, "0")} — ${issue.date}`;
---

<Layout
  title={`${site.name} — 第 ${issue.no} 期 · ${issue.date}`}
  description={site.tagline}
  active="home"
  issueLabel={issueLabel}
  issueDate={issue.date}
>
  <IssueHome issue={issue} />
</Layout>
