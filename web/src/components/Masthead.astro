---
import { site, latestIssue, issueHref, issueHomeHref } from "../lib/data";

interface Props {
  active: string;
  issueLabel?: string;
  /** 当前页所属期次；板块 tab 跟随它切换（不再跳回最新期）。缺省=最新期 */
  issueDate?: string;
}

const { active, issueLabel, issueDate } = Astro.props;
const latest = latestIssue;

// 期次上下文：浏览往期时 tab 全部指向该期的板块页
const currentDate = issueDate ?? latest?.date;
const isLatest = !currentDate || currentDate === latest?.date;

const tabs = [
  {
    id: "home",
    label: "首页",
    href: isLatest || !currentDate ? "index.html" : issueHomeHref(currentDate),
  },
  ...site.boards.map((b) => ({
    id: b.id,
    label: b.name,
    href: currentDate ? issueHref(b.id, currentDate) : "archive.html",
  })),
];
const rightLabel =
  issueLabel ??
  (latest ? `NO.${String(latest.no).padStart(3, "0")} — ${latest.date}` : "");
const currentLabel =
  active === "archive" ? "归档" : (tabs.find((t) => t.id === active)?.label ?? "首页");

// 期次下拉：只列保留窗口内有页面的期次（存目的归档期无页面，不进下拉防死链）
const pad3 = (n: number) => String(n).padStart(3, "0");
const issueEntries = site.issues
  .filter((i) => !i.archived)
  .sort((a, b) => b.date.localeCompare(a.date));
const currentEntry =
  issueEntries.find((i) => i.date === currentDate) ?? issueEntries[0];
const dateSummary = currentEntry
  ? `NO.${pad3(currentEntry.no)} · ${currentEntry.date.slice(5)}`
  : "期次";
---

<header class="masthead">
  <div class="container masthead__top">
    <a class="brand" href="index.html">
      <img class="brand__mark" src="logo-mark.svg" alt="" width="78" height="44" />
      <span class="brand__text">
        <span class="brand__name serif">{site.name}</span>
        <span class="mono brand__sub">{site.tagline}</span>
      </span>
    </a>
    <span class="mono masthead__issue">{rightLabel}</span>
  </div>
</header>

{/* 独立于 header 的导航条：移动端吸顶（sticky 受父容器约束，必须是兄弟元素） */}
<nav class="mastnav" aria-label="板块导航">
  <div class="container masthead__tabs">
    <ul class="tabs">
      {
        tabs.map((t) => (
          <li>
            <a
              class:list={["tab", { "tab--active": active === t.id }]}
              href={t.href}
              aria-current={active === t.id ? "page" : undefined}
            >
              <span class="tab__mark" aria-hidden="true" />
              {t.label}
            </a>
          </li>
        ))
      }
    </ul>
    <a
      class:list={["mono", "mono--link", "tabs__archive", { "tab--active-archive": active === "archive" }]}
      href="archive.html"
    >
      归档 ARCHIVE
    </a>

    <details class="tabdrop">
      <summary class="tabdrop__summary">
        <span class="tabdrop__mark" aria-hidden="true"></span>
        {currentLabel}
        <span class="tabdrop__caret" aria-hidden="true">▾</span>
      </summary>
      <div class="tabdrop__panel">
        {
          tabs.map((t) => (
            <a
              class:list={["tabdrop__item", { "tabdrop__item--active": active === t.id }]}
              href={t.href}
              aria-current={active === t.id ? "page" : undefined}
            >
              {t.label}
            </a>
          ))
        }
        <a
          class:list={["tabdrop__item", "tabdrop__item--archive",
            { "tabdrop__item--active": active === "archive" }]}
          href="archive.html"
        >
          归档 ARCHIVE
        </a>
      </div>
    </details>

    {/* 期次选择（全宽度可用）：选定某期后板块 tab 均留在该期；含回最新期快捷项 */}
    <details class="datedrop">
      <summary class="datedrop__summary mono" aria-label="选择期次">
        {dateSummary}
        <span class="datedrop__caret" aria-hidden="true">▾</span>
      </summary>
      <div class="datedrop__panel">
        {!isLatest && (
          <a class="datedrop__item datedrop__latest" href="index.html">
            回到最新一期 →
          </a>
        )}
        {
          issueEntries.map((e) => (
            <a
              class:list={["datedrop__item", "mono",
                { "datedrop__item--active": e.date === currentEntry?.date }]}
              href={e.date === latest?.date ? "index.html" : issueHomeHref(e.date)}
              aria-current={e.date === currentEntry?.date ? "page" : undefined}
            >
              <span class="datedrop__mark" aria-hidden="true" />
              NO.{pad3(e.no)} · {e.date.slice(5)} {e.weekday}
            </a>
          ))
        }
        <a class="datedrop__item datedrop__all mono" href="archive.html">
          更早期次见归档 →
        </a>
      </div>
    </details>

    {/* 分享本页：移动端走系统分享面板（微信/短信等），不支持时复制链接 */}
    <button class="sharebtn" type="button" aria-label="分享本页" title="分享本页">
      <svg
        class="sharebtn__icon"
        width="15"
        height="15"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M12 3v13" />
        <path d="M7 8l5-5 5 5" />
        <path d="M5 13v6a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2v-6" />
      </svg>
      <span class="mono sharebtn__label">分享</span>
    </button>
  </div>
</nav>

<script is:inline>
  // 分享键（渐进增强，页面渲染不依赖 JS）：Web Share API 优先（移动端拉起系统
  // 分享面板，微信/短信等在列）；不支持的环境复制链接并就地提示
  (function () {
    var btn = document.querySelector(".sharebtn");
    if (!btn) return;
    var label = btn.querySelector(".sharebtn__label");
    var idle = label ? label.textContent : "";
    var timer = null;
    function flash(msg) {
      if (!label) return;
      label.textContent = msg;
      btn.classList.add("sharebtn--flash");
      if (timer) clearTimeout(timer);
      timer = setTimeout(function () {
        label.textContent = idle;
        btn.classList.remove("sharebtn--flash");
      }, 1600);
    }
    btn.addEventListener("click", function () {
      var data = { title: document.title, url: location.href };
      if (navigator.share) {
        navigator.share(data).catch(function () {});  // 用户取消不提示
        return;
      }
      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(location.href).then(
          function () { flash("已复制"); },
          function () { flash("复制失败"); },
        );
      } else {
        window.prompt("复制本页链接：", location.href);
      }
    });
  })();
</script>

<style>
  .mastnav {
    border-bottom: 1px solid var(--hairline);
    background: var(--bg);
  }

  .masthead__top {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    padding-top: 30px;
    padding-bottom: 18px;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .brand__mark {
    height: 44px;
    width: auto;
  }

  .brand__text {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .brand__name {
    font-size: 27px;
    line-height: 1.1;
  }

  .brand__sub {
    letter-spacing: 0.2em;
  }

  .masthead__issue {
    font-size: 11px;
    color: var(--secondary);
  }

  /* 不设 overflow 滚动：≤960 已切下拉模式覆盖窄屏，桌面行宽实测 ~890px < 容器 992px。
     （此前的 overflow-x:auto 是 880 断点时代的横滑遗产——滚动容器会顺带裁掉
     期次下拉的纵向面板，2026-07-05 实际踩坑） */
  .masthead__tabs {
    display: flex;
    justify-content: flex-start;
    align-items: center;
    gap: 24px;
  }

  .masthead__tabs > a {
    flex: none;
  }

  /* 归档 + 期次选择靠右成组 */
  .tabs__archive {
    margin-left: auto;
  }

  .tabs {
    display: flex;
    gap: 34px;
    list-style: none;
    padding: 0;
    flex: none;
  }

  .tab {
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 10px 0 16px;
    font-size: 15px;
    color: var(--muted);
    transition: color 0.15s;
    white-space: nowrap;
  }

  .tab:hover {
    color: var(--ink);
  }

  .tab__mark {
    width: 5px;
    height: 5px;
    background: var(--accent);
    opacity: 0;
  }

  .tab--active {
    color: var(--ink);
    font-weight: 500;
  }

  .tab--active .tab__mark {
    opacity: 1;
  }

  .tab--active-archive {
    color: var(--ink);
  }

  /* ---- 期次选择下拉（原生 details，零 JS；全宽度可用）---- */
  .datedrop {
    position: relative;
    flex: none;
  }

  .datedrop__summary {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 10px 0 16px;
    font-size: 11px;
    letter-spacing: 0.08em;
    color: var(--secondary);
    list-style: none;
    cursor: pointer;
    white-space: nowrap;
    -webkit-tap-highlight-color: transparent;
    transition: color 0.15s;
  }

  .datedrop__summary:hover {
    color: var(--ink);
  }

  .datedrop__summary::-webkit-details-marker {
    display: none;
  }

  .datedrop__caret {
    color: var(--muted);
    font-size: 10px;
    transition: transform 0.15s;
  }

  .datedrop[open] .datedrop__caret {
    transform: rotate(180deg);
  }

  .datedrop__panel {
    position: absolute;
    top: 100%;
    right: 0;
    z-index: 30;
    min-width: 220px;
    max-height: 62vh;
    overflow-y: auto;
    padding: 6px 0;
    background: var(--bg);
    border: 1px solid var(--hairline);
    border-radius: 4px;
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.18);
  }

  .datedrop__item {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 11px 18px;
    font-size: 12px;
    letter-spacing: 0.06em;
    color: var(--secondary);
    white-space: nowrap;
  }

  .datedrop__item:hover {
    color: var(--ink);
  }

  .datedrop__mark {
    width: 5px;
    height: 5px;
    flex: none;
    background: var(--accent);
    opacity: 0;
  }

  .datedrop__item--active {
    color: var(--ink);
    font-weight: 500;
    background: var(--soft);
  }

  .datedrop__item--active .datedrop__mark {
    opacity: 1;
  }

  .datedrop__latest {
    font-family: var(--sans, inherit);
    font-size: 13px;
    color: var(--accent);
    border-bottom: 1px solid var(--hairline);
    margin-bottom: 6px;
  }

  .datedrop__latest:hover {
    color: var(--accent);
    opacity: 0.8;
  }

  .datedrop__all {
    margin-top: 6px;
    border-top: 1px solid var(--hairline);
    font-size: 11px;
    letter-spacing: 0.15em;
    color: var(--muted);
  }

  /* ---- 分享键（移动端功能：≤960 吸顶条内出现；桌面 tab 行宽度余量紧不放） ---- */
  .sharebtn {
    display: none;
    align-items: center;
    gap: 6px;
    padding: 12px 0;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--secondary);
    -webkit-tap-highlight-color: transparent;
    transition: color 0.15s;
    flex: none;
  }

  .sharebtn:hover {
    color: var(--ink);
  }

  .sharebtn__icon {
    display: block;
  }

  .sharebtn__label {
    font-size: 11px;
    letter-spacing: 0.08em;
  }

  .sharebtn--flash {
    color: var(--accent);
  }

  /* 点外部自动收起（零 JS）：同 tabdrop 的全屏点击层方案，全宽度生效 */
  .datedrop[open] .datedrop__summary::before {
    content: "";
    position: fixed;
    top: -100vh;
    left: -100vw;
    width: 300vw;
    height: 300vh;
    z-index: 29;
  }

  /* ---- 移动端板块下拉（原生 details，零 JS）---- */
  .tabdrop {
    display: none;
    position: relative;
  }

  .tabdrop__summary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 0 14px;
    font-size: 15px;
    font-weight: 500;
    color: var(--ink);
    list-style: none;
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
  }

  .tabdrop__summary::-webkit-details-marker {
    display: none;
  }

  .tabdrop__mark {
    width: 5px;
    height: 5px;
    background: var(--accent);
  }

  .tabdrop__caret {
    color: var(--muted);
    font-size: 11px;
    transition: transform 0.15s;
  }

  .tabdrop[open] .tabdrop__caret {
    transform: rotate(180deg);
  }

  .tabdrop__panel {
    position: absolute;
    top: 100%;
    left: 0;
    z-index: 30;
    min-width: 200px;
    padding: 6px 0;
    background: var(--bg);
    border: 1px solid var(--hairline);
    border-radius: 4px;
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.18);
  }

  .tabdrop__item {
    display: block;
    padding: 11px 18px;
    font-size: 14px;
    color: var(--secondary);
  }

  .tabdrop__item--active {
    color: var(--ink);
    font-weight: 500;
    background: var(--soft);
  }

  .tabdrop__item--archive {
    margin-top: 6px;
    border-top: 1px solid var(--hairline);
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.15em;
    color: var(--muted);
  }

  /* 断点 960：九个 tab + 归档约 930px 宽（2026-07-05 加设计板块后 +1 tab），
     溢出区间单行滚动条隐藏、归档滑出视口不可发现——提前切到下拉。
     与 topic 页返回条的吸顶偏移断点保持一致（同为 960） */
  @media (max-width: 960px) {
    /* 导航条吸顶：板块内浏览/读文章时随时可切换，不用滚回头部。
       高度固定 46px——topic 页的吸顶返回条以此为 top 偏移，两条叠放 */
    .mastnav {
      position: sticky;
      top: 0;
      z-index: 25;
      background: var(--bg);
      background: color-mix(in srgb, var(--bg) 92%, transparent);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
    }

    /* tab 行让位给下拉；overflow 改回 visible 以免裁掉下拉面板 */
    .masthead__tabs {
      overflow: visible;
      min-height: 46px;
      align-items: center;
    }

    .tabs,
    .tabs__archive {
      display: none;
    }

    .tabdrop {
      display: block;
    }

    .tabdrop__summary {
      padding: 12px 0;
    }

    /* 吸顶条内：板块下拉居左，期次下拉顶右 */
    .datedrop {
      margin-left: auto;
    }

    .datedrop__summary {
      padding: 12px 0;
    }

    .sharebtn {
      display: inline-flex;
    }

    /* 点外部自动收起（保持零 JS）：展开时 summary 生成一个全屏透明点击层，
       点菜单外任何位置＝点 summary＝原生收起；面板 z-index 30 在层之上不受影响。
       注意：.mastnav 的 backdrop-filter 会把 fixed 后代的包含块钳到导航条，
       所以不能用 inset:0，要用超尺寸盒覆盖视口 */
    .tabdrop[open] .tabdrop__summary::before {
      content: "";
      position: fixed;
      top: -100vh;
      left: -100vw;
      width: 300vw;
      height: 300vh;
      z-index: 29;
    }
  }

  @media (max-width: 640px) {
    .masthead__issue {
      display: none;
    }

    .brand__sub {
      display: none;
    }

    .masthead__top {
      padding-top: 20px;
      padding-bottom: 12px;
    }

    .brand__mark {
      height: 34px;
    }

    .brand__name {
      font-size: 22px;
    }
  }
</style>
