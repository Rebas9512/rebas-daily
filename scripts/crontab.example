# rebas_daily 四批备刊 crontab（服务器系统时区需设为 America/Chicago，
# 或用支持 CRON_TZ 的 cron 实现取消注释下一行）
# CRON_TZ=America/Chicago
#
# 安装: crontab -e 粘贴以下内容（替换 /opt/rebas_daily 为实际路径）
# 环境变量按需取消注释

# PATH=/usr/local/bin:/usr/bin:/bin          # 若 node/npm 不在默认 PATH
# REBAS_NPM=/usr/local/bin/npm
# HEALTHCHECK_URL=https://hc-ping.com/<ping-key>/rebas-batch-   # 末尾连字符，成功后拼批号 ping
# DEPLOY_CMD=/opt/rebas_daily/scripts/deploy_site.sh

1  0  * * *  /opt/rebas_daily/scripts/cron_batch.sh 1 >> /opt/rebas_daily/data/logs/batch.log 2>&1
0  5  * * *  /opt/rebas_daily/scripts/cron_batch.sh 2 >> /opt/rebas_daily/data/logs/batch.log 2>&1
0  10 * * *  /opt/rebas_daily/scripts/cron_batch.sh 3 >> /opt/rebas_daily/data/logs/batch.log 2>&1
0  15 * * *  /opt/rebas_daily/scripts/cron_batch.sh 4 >> /opt/rebas_daily/data/logs/batch.log 2>&1

# 日志月度截断（可选）
0  1  1 * *  tail -c 1M /opt/rebas_daily/data/logs/batch.log > /tmp/b.log && mv /tmp/b.log /opt/rebas_daily/data/logs/batch.log
