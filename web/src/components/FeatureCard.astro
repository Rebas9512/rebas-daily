---
import type { Topic } from "../lib/data";
import Tag from "./Tag.astro";

interface Props {
  topic: Topic;
  /** board 页专题网格用大号标题 */
  large?: boolean;
}

const { topic, large = false } = Astro.props;
const href = topic.page ?? topic.url;
const external = !topic.page && !!topic.url;
// 多图版式（艺术/设计）：图库 ≥2 时卡片最多铺 3 张；单图维持原版式
const gallery =
  topic.images && topic.images.length > 1 ? topic.images.slice(0, 3) : null;
---

<article class:list={["feat", { "feat--large": large }]}>
  {
    gallery ? (
      <div class:list={["feat__gallery", `feat__gallery--${gallery.length}`]}>
        {gallery.map((src) => (
          <figure class="feat__cell">
            <img
              src={src}
              alt=""
              loading="lazy"
              decoding="async"
              referrerpolicy="no-referrer"
              onerror="this.closest('figure').remove()"
            />
          </figure>
        ))}
      </div>
    ) : (
      topic.image && (
        <figure class="feat__fig">
          <img
            src={topic.image}
            alt=""
            loading="lazy"
            decoding="async"
            referrerpolicy="no-referrer"
            onerror="this.closest('figure').remove()"
          />
        </figure>
      )
    )
  }
  <div class="feat__meta">
    <Tag kind={topic.kind} />
    {topic.meta.length > 0 && <span class="mono">{topic.meta.join(" · ")}</span>}
    {topic.update_of && <span class="mono feat__follow">跟进</span>}
  </div>
  <h3 class="feat__title serif">
    {
      href ? (
        <a
          href={href}
          target={external ? "_blank" : undefined}
          rel={external ? "noopener" : undefined}
        >
          {topic.title}
        </a>
      ) : (
        topic.title
      )
    }
  </h3>
  <p class="feat__summary">{topic.summary}</p>
</article>

<style>
  .feat {
    border-top: 1px solid var(--hairline);
    padding-top: 16px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .feat__fig {
    margin: 0 0 4px;
    aspect-ratio: 3 / 2;
    overflow: hidden;
    border-radius: 4px;
    border: 1px solid var(--hairline);
    background: var(--soft);
  }

  .feat__fig img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* 多图卡片：2 张并列；3 张 = 主图占左双行 + 右侧两张竖排（杂志式） */
  .feat__gallery {
    display: grid;
    gap: 6px;
    margin: 0 0 4px;
  }

  .feat__gallery--2 {
    grid-template-columns: 1fr 1fr;
  }

  .feat__gallery--3 {
    grid-template-columns: 2fr 1fr;
  }

  .feat__gallery--3 .feat__cell:first-child {
    grid-row: span 2;
    aspect-ratio: auto;
    min-height: 0;
  }

  .feat__cell {
    margin: 0;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    border-radius: 4px;
    border: 1px solid var(--hairline);
    background: var(--soft);
  }

  .feat__cell img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .feat__meta {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .feat__follow {
    color: var(--accent);
  }

  .feat__title {
    font-size: 20px;
    line-height: 1.45;
  }

  .feat--large .feat__title {
    font-size: 22px;
  }

  .feat__title a:hover {
    color: var(--accent);
  }

  .feat__summary {
    font-size: 13px;
    line-height: 1.7;
    color: var(--secondary);
  }

  .feat--large .feat__summary {
    font-size: 13.5px;
  }
</style>
