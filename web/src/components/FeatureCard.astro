---
import type { Topic } from "../lib/data";
import Tag from "./Tag.astro";

interface Props {
  topic: Topic;
  /** board 页专题网格用大号标题 */
  large?: boolean;
}

const { topic, large = false } = Astro.props;
const href = topic.page ?? topic.url;
const external = !topic.page && !!topic.url;
---

<article class:list={["feat", { "feat--large": large }]}>
  {
    topic.image && (
      <figure class="feat__fig">
        <img
          src={topic.image}
          alt=""
          loading="lazy"
          decoding="async"
          referrerpolicy="no-referrer"
          onerror="this.closest('figure').remove()"
        />
      </figure>
    )
  }
  <div class="feat__meta">
    <Tag kind={topic.kind} />
    {topic.meta.length > 0 && <span class="mono">{topic.meta.join(" · ")}</span>}
    {topic.update_of && <span class="mono feat__follow">跟进</span>}
  </div>
  <h3 class="feat__title serif">
    {
      href ? (
        <a
          href={href}
          target={external ? "_blank" : undefined}
          rel={external ? "noopener" : undefined}
        >
          {topic.title}
        </a>
      ) : (
        topic.title
      )
    }
  </h3>
  <p class="feat__summary">{topic.summary}</p>
</article>

<style>
  .feat {
    border-top: 1px solid var(--hairline);
    padding-top: 16px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .feat__fig {
    margin: 0 0 4px;
    aspect-ratio: 3 / 2;
    overflow: hidden;
    border-radius: 4px;
    border: 1px solid var(--hairline);
    background: var(--soft);
  }

  .feat__fig img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .feat__meta {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .feat__follow {
    color: var(--accent);
  }

  .feat__title {
    font-size: 20px;
    line-height: 1.45;
  }

  .feat--large .feat__title {
    font-size: 22px;
  }

  .feat__title a:hover {
    color: var(--accent);
  }

  .feat__summary {
    font-size: 13px;
    line-height: 1.7;
    color: var(--secondary);
  }

  .feat--large .feat__summary {
    font-size: 13.5px;
  }
</style>
